# Data (Large)
raw_data/*
!raw_data/.gitkeep
ncbi_data/*
!ncbi_data/.gitkeep
results/*
!results/.gitkeep
common_refs/*.fna
common_refs/*.fasta
common_refs/*.cleaned*

# Nextflow / Analysis
.nextflow*
work/
analysis/work/
analysis/.nextflow/
analysis/.nextflow.log*

# Python
__pycache__/
*.py[cod]
*$py.class

# Design Outputs (Ignore transient results)
design/output/*
!design/output/.gitkeep
design/*.bed
design/*.csv
design/*.fasta
design/*.txt
design/ncbi_data/*
!design/ncbi_data/.gitkeep

# Logs
*.log
*.log.*
design_production.log

# OS
.DS_Store
Thumbs.db
