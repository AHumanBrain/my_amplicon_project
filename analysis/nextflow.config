params {
    // Default resources - optimized for standard design runs
    cpus = 4
    memory = '4 GB'
}

profiles {
    standard {
        process.executor = 'local'
    }
    
    conda {
        process.conda = "$baseDir/environment.yml"
    }
    
    docker {
        docker.enabled = true
        // You can map specific containers to processes here if needed
        // For simplicity, we assume a container with all tools or use conda
    }
}

// Ensure processes know to use the generic resource params
process {
    cpus = { params.cpus }
    memory = { params.memory }
}